  roles --> infra
  addr --> infra
  tenants --> infra
  services --> tenantRender
  edge --> edgeRender
  vni --> infra

  infra --> composite
  tenantRender --> composite
  edgeRender --> composite
  composite --> roleAware
  siteAttach --> composite