{## CATC: productFamily=Switches and Hubs, softwareType=IOS-XE, productSeries=Cisco Catalyst 9000 Series Virtual Switches ##}
{# FABRIC-OVERLAY.j2 - Standalone Overlay L2VNI/SVI Template #}
{# Generates L2VPN EVPN instances, VLANs, NVE members and SVIs for overlay networks #}
{% include "{{ TEMPLATE_PROJECT_NAME }}/DEFN-VRF.j2" %}
{% include "{{ TEMPLATE_PROJECT_NAME }}/DEFN-ROLES.j2" %}
{% include "{{ TEMPLATE_PROJECT_NAME }}/DEFN-OVERLAY.j2" %}
{% include "{{ TEMPLATE_PROJECT_NAME }}/DEFN-VNIOFFSETS.j2" %}
{% include "{{ TEMPLATE_PROJECT_NAME }}/FUNC-VRF-LOOKUP.j2" %}
{# Dereference Catalyst Center magic variable #}
{% set DEVICE_HOSTNAME = __device.hostname | default('', true) %}
{# Resolve the VRF objects for this device #}
{% set vrf_objs = [] %}
{{ vrf_definition(DEFN_VRF, DEFN_VRF_TO_NODE, DEVICE_HOSTNAME) }}
{# Dummy set to satisfy CatC static UDV scanner - overridden at runtime by for-loop #}
{% set vrf = {'name': '', 'id': '', 'mdt_default': '', 'mdt_data': ''} %}
{% if FABRIC_BGP_ASN is not none and vrf_objs is not none and DEVICE_HOSTNAME is not none %}
{# === ROUTER BGP SECTION === #}
{# Spine excluded: its ipv4 vrf AF is fully covered by FABRIC-EVPN L3OUT block #}
{# Border excluded: its ipv4 vrf AF (with mcluster peering) is fully covered by FABRIC-EVPN BORDER block #}
{% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['CLIENT'] %}
{% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['BORDER'] %}
{# BORDER: VRF address-family ipv4 vrf with mcluster neighbor peering is generated by FABRIC-EVPN.j2 - skip here #}
{% else %}
router bgp {{FABRIC_BGP_ASN}}
{% for vrf in vrf_objs %}
  {% for overlay in DEFN_OVERLAY %}
    {% if overlay.vrf == vrf.name %}
 address-family ipv4 vrf {{vrf.name}}
 advertise l2vpn evpn
 import path selection all
 redistribute connected
 maximum-paths ibgp {{ DEFN_NODE_ROLES['SPINE'] | length }}
 exit-address-family
 !
    {% endif %}
  {% endfor %}
{% endfor %}
{% endif %}{# end BORDER guard #}
{% endif %}{# end CLIENT guard for router bgp #}
{# === L2VPN EVPN INSTANCE SECTION === #}
{% for vrf in vrf_objs %}
  {% for overlay in DEFN_OVERLAY %}
  {% if overlay.vrf == vrf.name %}
    {% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['BORDER'] or DEVICE_HOSTNAME in DEFN_NODE_ROLES['SPINE']%}
    {# SKIP SPINE AND BORDER L2 DEFN #}
    {# AS NOT IN LOGIC IS NOT SUPPORTED IN THIS J2 ENGINE #}
    {% else %}
    {% for vlan, params in overlay.vlans.items() %}
    {% set l2evpn_id = vlan %}
l2vpn evpn instance {{l2evpn_id}} vlan-based
 encapsulation vxlan
 replication-type static
    !
    {% endfor %}
    {% endif %}
  {% endif %}
  {% endfor %}
{% endfor %}
{# === VLAN SECTION === #}
{% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['BORDER'] or DEVICE_HOSTNAME in DEFN_NODE_ROLES['SPINE'] %}
{# SKIP SPINE AND BORDER L2 VLAN DEFN #}
{% else %}
! @start-ignore-compliance
{% for vrf in vrf_objs %}
  {% for overlay in DEFN_OVERLAY %}
  {% if overlay.vrf == vrf.name %}
    {% for vlan, params in overlay.vlans.items() %}
vlan {{ vlan }}
 name DAG-{{params.name}}
!
    {% endfor %}
  {% endif %}
  {% endfor %}
{% endfor %}
! @end-ignore-compliance
{% endif %}
{# === VLAN CONFIGURATION SECTION === #}
{% for vrf in vrf_objs %}
  {% for overlay in DEFN_OVERLAY %}
  {% if overlay.vrf == vrf.name %}
  {% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['BORDER'] or DEVICE_HOSTNAME in DEFN_NODE_ROLES['SPINE']%}
  {# SKIP SPINE AND BORDER L2 DEFN #}
  {# AS NOT IN LOGIC IS NOT SUPPORTED IN THIS J2 ENGINE #}
  {% else %}
  {% for vlan, params in overlay.vlans.items() %}
  {% set l2evpn_id = vlan %}
  {% set l2vni_id = (L2VNIOFFSET | int) + (vlan | int) %}
vlan configuration {{ vlan }}
 member evpn-instance {{ l2evpn_id }} vni {{ l2vni_id }}
!
  {% endfor %}
  {% endif %}
  {% endif %}
  {% endfor %}
{% endfor %}
{# === INTERFACE NVE1 SECTION === #}
{# SKIP SPINE AND BORDER - no L2 NVE members; NVE1 for L3VNI is handled by FABRIC-NVE.j2 #}
{% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['BORDER'] or DEVICE_HOSTNAME in DEFN_NODE_ROLES['SPINE'] %}
{# SKIP NVE1 L2 SECTION FOR SPINE AND BORDER #}
{% else %}
interface nve1
{% for vrf in vrf_objs %}
  {% for overlay in DEFN_OVERLAY %}
  {% if overlay.vrf == vrf.name %}
  {% for vlan, params in overlay.vlans.items() %}
  {% set l2vni_id = (L2VNIOFFSET | int) + (vlan | int) %}
 member vni {{l2vni_id}} mcast-group {{params.bum_addr}}
  {% endfor %}
  {% endif %}
  {% endfor %}
{% endfor %}
{% endif %}
{# === INTERFACE VLANX SECTION === #}
{# Enable VRF-aware DHCP relay: inserts Option 82 sub-opt 151 (VPN-ID = VRF name) so DHCP server selects the correct VRF pool #}
{% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['BORDER'] or DEVICE_HOSTNAME in DEFN_NODE_ROLES['SPINE'] %}
{# SKIP ip dhcp relay information option vpn for SPINE and BORDER - no L2 SVIs #}
{% else %}
ip dhcp relay information option vpn
{% endif %}
{% for vrf in vrf_objs %}
{% for overlay in DEFN_OVERLAY %}
  {% if overlay.vrf == vrf.name %}
  {% set vrf_obj = DEFN_VRF | selectattr('name', 'equalto', vrf.name) | list | first %}
  {% set dhcp_source_interface = 'Loopback' + vrf_obj.id %}
  {% if DEVICE_HOSTNAME in DEFN_NODE_ROLES['BORDER'] or DEVICE_HOSTNAME in DEFN_NODE_ROLES['SPINE']%}
  {# SKIP SPINE AND BORDER L2 DEFN #}
  {# AS NOT IN LOGIC IS NOT SUPPORTED IN THIS J2 ENGINE #}
  {% else %}
  {% for vlan, params in overlay.vlans.items() %}
interface Vlan{{ vlan }}
 description DAG-{{ params.name }}
 vrf forwarding {{ overlay.vrf }}
 mac-address {{ params.mac }}
 ip address {{ params.ipaddr }}
 ip dhcp relay source-interface {{ dhcp_source_interface }}
 ip helper-address {{ params.dhcp_helper }}
 ip pim sparse-mode
!
  {% endfor %}
  {% endif %}
  {% endif %}
{% endfor %}
{% endfor %}
{% endif %}
