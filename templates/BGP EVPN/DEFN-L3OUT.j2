{## CATC: productFamily=Switches and Hubs, softwareType=IOS-XE, productSeries=Cisco Catalyst 9000 Series Virtual Switches ##}
{# ============================================================ #}
{# DEFN_L3OUT — L3 EXTERNAL CONNECTIVITY DEFINITIONS           #}
{#                                                              #}
{# List of per-node L3OUT entries. Each entry defines one       #}
{# spine's external uplinks to the upstream core router.        #}
{#                                                              #}
{# Fields:                                                      #}
{#   vrf          — VRF name; must match an entry in DEFN_VRF   #}
{#   node         — FQDN matching the Catalyst Center inventory  #}
{#   neighbour_asn — BGP ASN of the upstream core router        #}
{#   interfaces   — list of sub-interface dicts (see below)     #}
{#                                                              #}
{# Interface dict fields:                                       #}
{#   ifname   — dot1Q sub-interface (e.g. Gi1/0/5.2)           #}
{#   parent   — parent physical interface (no switchport)       #}
{#   name     — human-readable uplink label (informational)     #}
{#   vlan     — dot1Q encapsulation VLAN ID                     #}
{#   ipaddr   — IP address + mask assigned to the sub-interface #}
{#   neighbour — peer IP of the upstream core router            #}
{#                                                              #}
{# Consumed by:                                                 #}
{#   FABRIC-L3OUT.j2  — renders parent + sub-interface CLI      #}
{#   FABRIC-EVPN.j2   — renders BGP neighbor stanzas in        #}
{#                       address-family ipv4 vrf on Spines      #}
{#                                                              #}
{# NOTE: 'interfaces' is a flat list (not a dict) to avoid      #}
{# CatC Jinja2 dict-iteration non-determinism. See              #}
{# CATC-JINJA-DICT-ITERATION-FIX.md for details.               #}
{# ============================================================ #}
{% set DEFN_L3OUT = [
  {
    'vrf': 'red',
    'node': 'Spine-01.dcloud.cisco.com',
    'neighbour_asn': '65002',
    'interfaces': [
      {'ifname': 'GigabitEthernet1/0/5.2', 'parent': 'GigabitEthernet1/0/5', 'name': 'uplink1', 'vlan': '2', 'ipaddr': '198.19.2.50 255.255.255.252', 'neighbour': '198.19.2.49'},
      {'ifname': 'GigabitEthernet1/0/6.2', 'parent': 'GigabitEthernet1/0/6', 'name': 'uplink2', 'vlan': '2', 'ipaddr': '198.19.2.54 255.255.255.252', 'neighbour': '198.19.2.53'}
    ]
  },
  {
    'vrf': 'red',
    'node': 'Spine-02.dcloud.cisco.com',
    'neighbour_asn': '65002',
    'interfaces': [
      {'ifname': 'GigabitEthernet1/0/5.2', 'parent': 'GigabitEthernet1/0/5', 'name': 'uplink1', 'vlan': '2', 'ipaddr': '198.19.2.58 255.255.255.252', 'neighbour': '198.19.2.57'},
      {'ifname': 'GigabitEthernet1/0/6.2', 'parent': 'GigabitEthernet1/0/6', 'name': 'uplink2', 'vlan': '2', 'ipaddr': '198.19.2.62 255.255.255.252', 'neighbour': '198.19.2.61'}
    ]
  }
] %}
{# ============================================================ #}
{# DEFN_L3OUT_AGGREGATES — BGP SUMMARY PREFIXES ADVERTISED     #}
{# TO THE UPSTREAM CORE VIA THE L3OUT BGP SESSION              #}
{#                                                              #}
{# Each entry is advertised as:                                 #}
{#   aggregate-address <prefix> summary-only                    #}
{# inside the 'address-family ipv4 vrf <vrf>' block on Spines  #}
{# (FABRIC-EVPN.j2, L3OUT section). 'summary-only' suppresses  #}
{# the more-specific /24 host routes so only the aggregate is   #}
{# leaked to the external fabric / core router.                 #}
{#                                                              #}
{# Entries must correspond to the 'network' values defined in   #}
{# DEFN_OVERLAY for the L3OUT VRF (currently 'red'). Add one   #}
{# entry per VLAN subnet that should be reachable externally.   #}
{# ============================================================ #}
{% set DEFN_L3OUT_AGGREGATES = ["198.18.100.0 255.255.255.0",
                                "198.18.101.0 255.255.255.0",
                                "198.18.102.0 255.255.255.0"]
%}
{# ============================================================ #}
{# DEFN_L3OUT_NODES — SINGLE TOGGLE FOR ALL L3OUT OUTPUT        #}
{#                                                              #}
{# List every node hostname that participates in L3OUT.         #}
{# Values must match the 'node' field entries in DEFN_L3OUT.    #}
{#                                                              #}
{# To DISABLE all L3OUT output (e.g. when the L3OUT VRF tenant  #}
{# is not present in this deployment):                          #}
{#   1. Set DEFN_L3OUT_NODES to []                              #}
{#   2. Remove the L3OUT VRF IDs from the corresponding Spine   #}
{#      entries in DEFN_VRF_TO_NODE (DEFN-VRF.j2) to prevent   #}
{#      orphaned VRF/NVE config on Spines with no external      #}
{#      connectivity.                                           #}
{# ============================================================ #}
{% set DEFN_L3OUT_NODES = ['Spine-01.dcloud.cisco.com',
                           'Spine-02.dcloud.cisco.com'] %}
{# End of File #}
